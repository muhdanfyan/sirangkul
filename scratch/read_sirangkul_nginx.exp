#!/usr/bin/expect -f
set timeout 30
set host "89.233.105.92"
set user "sirangkul"
set pass "Sfgxjs4H38DQb7K"

spawn ssh -o StrictHostKeyChecking=no $user@$host
expect "password:"
send "$pass\r"
expect "$ "

# Find the config file for sirangkul
send "grep -l 'sirangkul.man2kotamakassar.sch.id' /etc/nginx/sites-enabled/*\r"
expect "$ "

# Read the config
send "cat /etc/nginx/sites-enabled/sirangkul\r"
expect "$ "

send "exit\r"
expect eof
